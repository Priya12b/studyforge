# ============================================================
# StudyForge AI Service — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — only commit this .env.example file.
# ============================================================

# --- Server ---
PORT=8000
ENVIRONMENT=development   # development | staging | production

# --- LLM Provider Keys ---
# Get a FREE Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — only if you have an OpenAI account
OPENAI_API_KEY=your_openai_api_key_here

# --- Model Routing ---
# LOCAL development: use 'ollama' (requires Ollama installed locally)
# PRODUCTION / Render deployment: use 'gemini'
DEFAULT_PROVIDER=gemini
FALLBACK_PROVIDER=gemini
COMPLEX_REASONING_PROVIDER=gemini

# --- Ollama (Local only, ignored in production) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# --- Vector Database ---
CHROMA_PERSIST_DIR=./chroma_data

# --- Memory Backend ---
# Use 'local' for development, 'redis' if you have a Redis instance
MEMORY_BACKEND=local
REDIS_URL=redis://localhost:6379/0

# --- Rate Limits ---
MAX_TOKENS_PER_REQUEST=4096
MODEL_TIMEOUT_SECONDS=120
MAX_RETRIES=3
